# ─────────────────────────────────────────────────────────────────────────────
# npm-node_modules.tf
# ECS Fargate deployment — npm vulnerable packages demo for Orca Security
# Matches existing fargate-cloud2dev pattern (ap-southeast-1)
# ─────────────────────────────────────────────────────────────────────────────

terraform {
  required_providers {
    aws = { source = "hashicorp/aws" }
  }
  backend "s3" {
    bucket = "fargate-cloud2dev-tfstate"
    key    = "fargate-cloud2dev/npm-node_modules/terraform.tfstate"
    region = "ap-southeast-1"
  }
}

locals {
  name_prefix = "npm-node-modules"
  aws_region  = "ap-southeast-1"
  app_port    = 3000
}

data "aws_caller_identity" "current" {}

provider "aws" {
  region = local.aws_region
}

# ─────────────────────────────────────────────────────────────────────────────
# ECR Repository — push your built image here
# ─────────────────────────────────────────────────────────────────────────────
resource "aws_ecr_repository" "npm_node_modules" {
  name                 = "${local.name_prefix}-demo"
  image_tag_mutability = "MUTABLE"

  image_scanning_configuration {
    scan_on_push = true
  }

  tags = {
    Name    = "${local.name_prefix}-demo"
    Purpose = "orca-vuln-demo"
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# VPC — reuse existing cloud2dev VPC if available, else data source it
# ─────────────────────────────────────────────────────────────────────────────
data "aws_vpc" "cloud2dev" {
  filter {
    name   = "tag:Name"
    values = ["cloud2dev-test-vpc"]
  }
}

data "aws_subnets" "public" {
  filter {
    name   = "vpc-id"
    values = [data.aws_vpc.cloud2dev.id]
  }
  filter {
    name   = "tag:Name"
    values = ["*public*"]
  }
}

data "aws_subnets" "private" {
  filter {
    name   = "vpc-id"
    values = [data.aws_vpc.cloud2dev.id]
  }
  filter {
    name   = "tag:Name"
    values = ["*private*"]
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# Security Groups
# ─────────────────────────────────────────────────────────────────────────────
resource "aws_security_group" "alb" {
  name        = "${local.name_prefix}-alb-sg"
  description = "ALB security group for npm-node_modules demo"
  vpc_id      = data.aws_vpc.cloud2dev.id

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = { Name = "${local.name_prefix}-alb-sg" }
}

resource "aws_security_group" "ecs_task" {
  name        = "${local.name_prefix}-ecs-sg"
  description = "ECS task security group for npm-node_modules demo"
  vpc_id      = data.aws_vpc.cloud2dev.id

  ingress {
    from_port       = local.app_port
    to_port         = local.app_port
    protocol        = "tcp"
    security_groups = [aws_security_group.alb.id]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = { Name = "${local.name_prefix}-ecs-sg" }
}

# ─────────────────────────────────────────────────────────────────────────────
# ALB
# ─────────────────────────────────────────────────────────────────────────────
resource "aws_lb" "npm_node_modules" {
  name               = "${local.name_prefix}-alb"
  internal           = false
  load_balancer_type = "application"
  security_groups    = [aws_security_group.alb.id]
  subnets            = data.aws_subnets.public.ids

  tags = { Name = "${local.name_prefix}-alb" }
}

resource "aws_lb_target_group" "npm_node_modules" {
  name        = "${local.name_prefix}-tg"
  port        = local.app_port
  protocol    = "HTTP"
  vpc_id      = data.aws_vpc.cloud2dev.id
  target_type = "ip"

  health_check {
    path                = "/health"
    healthy_threshold   = 2
    unhealthy_threshold = 3
    interval            = 30
  }

  tags = { Name = "${local.name_prefix}-tg" }
}

resource "aws_lb_listener" "http" {
  load_balancer_arn = aws_lb.npm_node_modules.arn
  port              = 80
  protocol          = "HTTP"

  default_action {
    type             = "forward"
    target_group_arn = aws_lb_target_group.npm_node_modules.arn
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# IAM — Task Execution Role (matches mal-outbound-exec-role pattern)
# ─────────────────────────────────────────────────────────────────────────────
resource "aws_iam_role" "ecs_exec" {
  name = "${local.name_prefix}-exec-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Effect    = "Allow"
      Principal = { Service = "ecs-tasks.amazonaws.com" }
      Action    = "sts:AssumeRole"
    }]
  })

  tags = { Name = "${local.name_prefix}-exec-role" }
}

resource "aws_iam_role_policy_attachment" "ecs_exec_policy" {
  role       = aws_iam_role.ecs_exec.name
  policy_arn = "arn:aws:iam::aws:policy/service-role/AmazonECSTaskExecutionRolePolicy"
}

# Allow reading Orca sensor secrets (matches your existing pattern)
resource "aws_iam_role_policy" "orca_secrets" {
  name = "AllowOrcaSensorSecretAccess"
  role = aws_iam_role.ecs_exec.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Effect   = "Allow"
      Action   = "secretsmanager:GetSecretValue"
      Resource = "arn:aws:secretsmanager:ap-southeast-1:${data.aws_caller_identity.current.account_id}:secret:orca-sensor-*"
    }]
  })
}

# ─────────────────────────────────────────────────────────────────────────────
# IAM — Task Role (runtime permissions for the app)
# ─────────────────────────────────────────────────────────────────────────────
resource "aws_iam_role" "ecs_task" {
  name = "${local.name_prefix}-task-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Effect    = "Allow"
      Principal = { Service = "ecs-tasks.amazonaws.com" }
      Action    = "sts:AssumeRole"
    }]
  })

  tags = { Name = "${local.name_prefix}-task-role" }
}

# ─────────────────────────────────────────────────────────────────────────────
# CloudWatch Log Group
# ─────────────────────────────────────────────────────────────────────────────
resource "aws_cloudwatch_log_group" "npm_node_modules" {
  name              = "/ecs/${local.name_prefix}"
  retention_in_days = 7

  tags = { Name = "${local.name_prefix}-logs" }
}

# ─────────────────────────────────────────────────────────────────────────────
# ECS Cluster
# ─────────────────────────────────────────────────────────────────────────────
resource "aws_ecs_cluster" "npm_node_modules" {
  name = "${local.name_prefix}-cluster"

  setting {
    name  = "containerInsights"
    value = "enabled"
  }

  tags = { Name = "${local.name_prefix}-cluster" }
}

# ─────────────────────────────────────────────────────────────────────────────
# ECS Task Definition
# Packages pulled at build time into the image:
#   express@4.17.1       — CVE-2022-24999 (older qs)
#   axios@0.21.1         — CVE-2021-3749  (SSRF / ReDoS)
#   cookie-parser@1.4.3  — pulls cookie@0.3.1 (CVE-2024-47764)
#   lodash@4.17.19       — CVE-2021-23337 (prototype pollution)
#   node-fetch@2.6.1     — CVE-2022-0235  (open redirect)
# ─────────────────────────────────────────────────────────────────────────────
resource "aws_ecs_task_definition" "npm_node_modules" {
  family                   = "${local.name_prefix}-task"
  requires_compatibilities = ["FARGATE"]
  network_mode             = "awsvpc"
  cpu                      = "256"
  memory                   = "512"
  execution_role_arn       = aws_iam_role.ecs_exec.arn
  task_role_arn            = aws_iam_role.ecs_task.arn

  container_definitions = jsonencode([
    {
      name      = "${local.name_prefix}-app"
      image     = "${aws_ecr_repository.npm_node_modules.repository_url}:latest"
      essential = true

      portMappings = [
        {
          containerPort = local.app_port
          protocol      = "tcp"
        }
      ]

      environment = [
        { name = "PORT",     value = tostring(local.app_port) },
        { name = "NODE_ENV", value = "production" }
      ]

      logConfiguration = {
        logDriver = "awslogs"
        options = {
          "awslogs-group"         = aws_cloudwatch_log_group.npm_node_modules.name
          "awslogs-region"        = local.aws_region
          "awslogs-stream-prefix" = "ecs"
        }
      }

      healthCheck = {
        command     = ["CMD-SHELL", "wget -qO- http://localhost:${local.app_port}/health || exit 1"]
        interval    = 30
        timeout     = 5
        retries     = 3
        startPeriod = 15
      }
    }
  ])

  tags = {
    Name    = "${local.name_prefix}-task"
    Purpose = "orca-vuln-demo"
    Packages = "express-4.17.1,axios-0.21.1,cookie-parser-1.4.3,lodash-4.17.19,node-fetch-2.6.1"
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# ECS Service
# ─────────────────────────────────────────────────────────────────────────────
resource "aws_ecs_service" "npm_node_modules" {
  name            = "${local.name_prefix}-svc"
  cluster         = aws_ecs_cluster.npm_node_modules.id
  task_definition = aws_ecs_task_definition.npm_node_modules.arn
  desired_count   = 1
  launch_type     = "FARGATE"

  network_configuration {
    subnets          = data.aws_subnets.private.ids
    security_groups  = [aws_security_group.ecs_task.id]
    assign_public_ip = false
  }

  load_balancer {
    target_group_arn = aws_lb_target_group.npm_node_modules.arn
    container_name   = "${local.name_prefix}-app"
    container_port   = local.app_port
  }

  depends_on = [aws_lb_listener.http]

  tags = {
    Name    = "${local.name_prefix}-svc"
    Purpose = "orca-vuln-demo"
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# Outputs
# ─────────────────────────────────────────────────────────────────────────────
output "ecr_repo_url" {
  description = "Push your Docker image here"
  value       = aws_ecr_repository.npm_node_modules.repository_url
}

output "alb_dns" {
  description = "Access the demo app at this URL"
  value       = "http://${aws_lb.npm_node_modules.dns_name}"
}

output "ecs_cluster" {
  value = aws_ecs_cluster.npm_node_modules.name
}

output "ecs_service" {
  value = aws_ecs_service.npm_node_modules.name
}

output "docker_push_commands" {
  description = "Commands to build and push the image"
  value       = <<-EOT
    aws ecr get-login-password --region ${local.aws_region} | \
      docker login --username AWS --password-stdin ${aws_ecr_repository.npm_node_modules.repository_url}

    docker build -t ${local.name_prefix}-demo .
    docker tag ${local.name_prefix}-demo:latest ${aws_ecr_repository.npm_node_modules.repository_url}:latest
    docker push ${aws_ecr_repository.npm_node_modules.repository_url}:latest
  EOT
}
