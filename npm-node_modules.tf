# ─────────────────────────────────────────────────────────────────────────────
# npm-node_modules.tf
# ECS Fargate — 5 npm package version containers for Orca Security demo
# Cluster: npm-node-modules-cluster
# Services: v1-oldest / v2-old / v3-mid / v4-newer / v5-latest
# Region: ap-southeast-1
# ─────────────────────────────────────────────────────────────────────────────

terraform {
  required_providers {
    aws = { source = "hashicorp/aws" }
  }
  backend "s3" {
    bucket = "fargate-cloud2dev-tfstate"
    key    = "fargate-cloud2dev/npm-node_modules/terraform.tfstate"
    region = "ap-southeast-1"
  }
}

locals {
  name_prefix = "npm-node-modules"
  aws_region  = "ap-southeast-1"
  app_port    = 3000

  variants = {
    v1 = {
      label      = "v1-oldest"
      node_ver   = "node:12-alpine"
      express    = "4.16.0"
      axios      = "0.19.0"
      cookie     = "1.4.3"
      lodash     = "4.17.15"
      nodefetch  = "2.6.0"
      cpu        = "256"
      memory     = "512"
    }
    v2 = {
      label      = "v2-old"
      node_ver   = "node:14-alpine"
      express    = "4.17.1"
      axios      = "0.21.1"
      cookie     = "1.4.4"
      lodash     = "4.17.19"
      nodefetch  = "2.6.1"
      cpu        = "256"
      memory     = "512"
    }
    v3 = {
      label      = "v3-mid"
      node_ver   = "node:16-alpine"
      express    = "4.18.1"
      axios      = "0.24.0"
      cookie     = "1.4.5"
      lodash     = "4.17.20"
      nodefetch  = "2.6.5"
      cpu        = "256"
      memory     = "512"
    }
    v4 = {
      label      = "v4-newer"
      node_ver   = "node:18-alpine"
      express    = "4.18.2"
      axios      = "0.27.2"
      cookie     = "1.4.6"
      lodash     = "4.17.21"
      nodefetch  = "2.6.7"
      cpu        = "256"
      memory     = "512"
    }
    v5 = {
      label      = "v5-latest"
      node_ver   = "node:20-alpine"
      express    = "4.19.2"
      axios      = "1.6.8"
      cookie     = "1.4.6"
      lodash     = "4.17.21"
      nodefetch  = "3.3.2"
      cpu        = "256"
      memory     = "512"
    }
  }
}

data "aws_caller_identity" "current" {}

provider "aws" {
  region = local.aws_region
}

# ─────────────────────────────────────────────────────────────────────────────
# VPC
# ─────────────────────────────────────────────────────────────────────────────
data "aws_vpc" "cloud2dev" {
  filter {
    name   = "tag:Name"
    values = ["cloud2dev-test-vpc"]
  }
}

data "aws_subnets" "public" {
  filter {
    name   = "vpc-id"
    values = [data.aws_vpc.cloud2dev.id]
  }
  filter {
    name   = "tag:Name"
    values = ["*public*"]
  }
}

data "aws_subnets" "private" {
  filter {
    name   = "vpc-id"
    values = [data.aws_vpc.cloud2dev.id]
  }
  filter {
    name   = "tag:Name"
    values = ["*private*"]
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# ECR Repositories — one per variant
# ─────────────────────────────────────────────────────────────────────────────
resource "aws_ecr_repository" "variant" {
  for_each             = local.variants
  name                 = "${local.name_prefix}-${each.key}"
  image_tag_mutability = "MUTABLE"

  image_scanning_configuration {
    scan_on_push = true
  }

  tags = {
    Name    = "${local.name_prefix}-${each.key}"
    Variant = each.value.label
    Purpose = "orca-vuln-demo"
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# Security Groups
# ─────────────────────────────────────────────────────────────────────────────
resource "aws_security_group" "alb" {
  name        = "${local.name_prefix}-alb-sg"
  description = "ALB SG for npm-node-modules demo"
  vpc_id      = data.aws_vpc.cloud2dev.id

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = { Name = "${local.name_prefix}-alb-sg" }
}

resource "aws_security_group" "ecs_tasks" {
  name        = "${local.name_prefix}-ecs-sg"
  description = "ECS tasks SG for npm-node-modules demo"
  vpc_id      = data.aws_vpc.cloud2dev.id

  ingress {
    from_port       = local.app_port
    to_port         = local.app_port
    protocol        = "tcp"
    security_groups = [aws_security_group.alb.id]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = { Name = "${local.name_prefix}-ecs-sg" }
}

# ─────────────────────────────────────────────────────────────────────────────
# ALB — one shared ALB with path-based routing per variant
# ─────────────────────────────────────────────────────────────────────────────
resource "aws_lb" "main" {
  name               = "${local.name_prefix}-alb"
  internal           = false
  load_balancer_type = "application"
  security_groups    = [aws_security_group.alb.id]
  subnets            = data.aws_subnets.public.ids

  tags = { Name = "${local.name_prefix}-alb" }
}

resource "aws_lb_target_group" "variant" {
  for_each    = local.variants
  name        = "${local.name_prefix}-${each.key}-tg"
  port        = local.app_port
  protocol    = "HTTP"
  vpc_id      = data.aws_vpc.cloud2dev.id
  target_type = "ip"

  health_check {
    path                = "/health"
    healthy_threshold   = 2
    unhealthy_threshold = 3
    interval            = 30
  }

  tags = {
    Name    = "${local.name_prefix}-${each.key}-tg"
    Variant = each.value.label
  }
}

resource "aws_lb_listener" "http" {
  load_balancer_arn = aws_lb.main.arn
  port              = 80
  protocol          = "HTTP"

  default_action {
    type             = "forward"
    target_group_arn = aws_lb_target_group.variant["v1"].arn
  }
}

resource "aws_lb_listener_rule" "variant" {
  for_each     = local.variants
  listener_arn = aws_lb_listener.http.arn
  priority     = index(keys(local.variants), each.key) + 10

  action {
    type             = "forward"
    target_group_arn = aws_lb_target_group.variant[each.key].arn
  }

  condition {
    path_pattern {
      values = ["/${each.key}/*", "/${each.key}"]
    }
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# IAM
# ─────────────────────────────────────────────────────────────────────────────
resource "aws_iam_role" "ecs_exec" {
  name = "${local.name_prefix}-exec-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Effect    = "Allow"
      Principal = { Service = "ecs-tasks.amazonaws.com" }
      Action    = "sts:AssumeRole"
    }]
  })

  tags = { Name = "${local.name_prefix}-exec-role" }
}

resource "aws_iam_role_policy_attachment" "ecs_exec_policy" {
  role       = aws_iam_role.ecs_exec.name
  policy_arn = "arn:aws:iam::aws:policy/service-role/AmazonECSTaskExecutionRolePolicy"
}

resource "aws_iam_role_policy" "orca_secrets" {
  name = "AllowOrcaSensorSecretAccess"
  role = aws_iam_role.ecs_exec.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Effect   = "Allow"
      Action   = "secretsmanager:GetSecretValue"
      Resource = "arn:aws:secretsmanager:ap-southeast-1:${data.aws_caller_identity.current.account_id}:secret:orca-sensor-*"
    }]
  })
}

resource "aws_iam_role" "ecs_task" {
  name = "${local.name_prefix}-task-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Effect    = "Allow"
      Principal = { Service = "ecs-tasks.amazonaws.com" }
      Action    = "sts:AssumeRole"
    }]
  })

  tags = { Name = "${local.name_prefix}-task-role" }
}

# ─────────────────────────────────────────────────────────────────────────────
# CloudWatch Log Groups
# ─────────────────────────────────────────────────────────────────────────────
resource "aws_cloudwatch_log_group" "variant" {
  for_each          = local.variants
  name              = "/ecs/${local.name_prefix}-${each.key}"
  retention_in_days = 7

  tags = {
    Name    = "${local.name_prefix}-${each.key}-logs"
    Variant = each.value.label
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# ECS Cluster
# ─────────────────────────────────────────────────────────────────────────────
resource "aws_ecs_cluster" "main" {
  name = "${local.name_prefix}-cluster"

  setting {
    name  = "containerInsights"
    value = "enabled"
  }

  tags = {
    Name    = "${local.name_prefix}-cluster"
    Purpose = "orca-vuln-demo"
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# ECS Task Definitions — tags use only safe characters (no commas)
# ─────────────────────────────────────────────────────────────────────────────
resource "aws_ecs_task_definition" "variant" {
  for_each                 = local.variants
  family                   = "${local.name_prefix}-${each.key}-task"
  requires_compatibilities = ["FARGATE"]
  network_mode             = "awsvpc"
  cpu                      = each.value.cpu
  memory                   = each.value.memory
  execution_role_arn       = aws_iam_role.ecs_exec.arn
  task_role_arn            = aws_iam_role.ecs_task.arn

  container_definitions = jsonencode([
    {
      name      = "${local.name_prefix}-${each.key}"
      image     = "${aws_ecr_repository.variant[each.key].repository_url}:latest"
      essential = true

      portMappings = [
        {
          containerPort = local.app_port
          protocol      = "tcp"
        }
      ]

      environment = [
        { name = "PORT",        value = tostring(local.app_port) },
        { name = "NODE_ENV",    value = "production" },
        { name = "VARIANT",     value = each.value.label },
        { name = "EXPRESS_VER", value = each.value.express },
        { name = "AXIOS_VER",   value = each.value.axios },
        { name = "COOKIE_VER",  value = each.value.cookie }
      ]

      logConfiguration = {
        logDriver = "awslogs"
        options = {
          "awslogs-group"         = aws_cloudwatch_log_group.variant[each.key].name
          "awslogs-region"        = local.aws_region
          "awslogs-stream-prefix" = "ecs"
        }
      }

      healthCheck = {
        command     = ["CMD-SHELL", "wget -qO- http://localhost:${local.app_port}/health || exit 1"]
        interval    = 30
        timeout     = 5
        retries     = 3
        startPeriod = 15
      }
    }
  ])

  tags = {
    Name          = "${local.name_prefix}-${each.key}-task"
    Variant       = each.value.label
    Purpose       = "orca-vuln-demo"
    express       = each.value.express
    axios         = each.value.axios
    cookie_parser = each.value.cookie
    lodash        = each.value.lodash
    node_fetch    = each.value.nodefetch
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# ECS Services
# ─────────────────────────────────────────────────────────────────────────────
resource "aws_ecs_service" "variant" {
  for_each        = local.variants
  name            = "${local.name_prefix}-${each.key}-svc"
  cluster         = aws_ecs_cluster.main.id
  task_definition = aws_ecs_task_definition.variant[each.key].arn
  desired_count   = 1
  launch_type     = "FARGATE"

  network_configuration {
    subnets          = data.aws_subnets.private.ids
    security_groups  = [aws_security_group.ecs_tasks.id]
    assign_public_ip = false
  }

  load_balancer {
    target_group_arn = aws_lb_target_group.variant[each.key].arn
    container_name   = "${local.name_prefix}-${each.key}"
    container_port   = local.app_port
  }

  depends_on = [aws_lb_listener.http]

  tags = {
    Name    = "${local.name_prefix}-${each.key}-svc"
    Variant = each.value.label
    Purpose = "orca-vuln-demo"
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# Outputs
# ─────────────────────────────────────────────────────────────────────────────
output "cluster_name" {
  value = aws_ecs_cluster.main.name
}

output "alb_dns" {
  description = "Base URL — append /v1 through /v5 to hit each variant"
  value       = "http://${aws_lb.main.dns_name}"
}

output "service_urls" {
  value = {
    v1_oldest = "http://${aws_lb.main.dns_name}/v1"
    v2_old    = "http://${aws_lb.main.dns_name}/v2"
    v3_mid    = "http://${aws_lb.main.dns_name}/v3"
    v4_newer  = "http://${aws_lb.main.dns_name}/v4"
    v5_latest = "http://${aws_lb.main.dns_name}/v5"
  }
}

output "ecr_repos" {
  value = {
    for k, v in aws_ecr_repository.variant : k => v.repository_url
  }
}

output "docker_build_and_push" {
  description = "Build and push all 5 images after terraform apply"
  value       = <<-EOT
    ACCOUNT=${data.aws_caller_identity.current.account_id}
    REGION=${local.aws_region}

    aws ecr get-login-password --region $REGION | \
      docker login --username AWS --password-stdin $ACCOUNT.dkr.ecr.$REGION.amazonaws.com

    for v in v1 v2 v3 v4 v5; do
      cd $v
      docker build -t ${local.name_prefix}-$v .
      docker tag ${local.name_prefix}-$v:latest $ACCOUNT.dkr.ecr.$REGION.amazonaws.com/${local.name_prefix}-$v:latest
      docker push $ACCOUNT.dkr.ecr.$REGION.amazonaws.com/${local.name_prefix}-$v:latest
      cd ..
    done
  EOT
}
